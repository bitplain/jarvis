APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=https://example.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME= # auto-derived from getMe
TELEGRAM_WEBHOOK_SECRET= # generated locally, allowed chars A-Z a-z 0-9 _ -
ADMIN_TELEGRAM_IDS= # can be derived after sending /start to bot
ADMIN_API_TOKEN= # generated locally
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis_password_change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
MEMORY_MAX_MESSAGES=20
LLM_PRIMARY_PROVIDER=yandex
LLM_FALLBACK_PROVIDER=openrouter
REGULAR_ASSISTANT_ENABLED=true
FORWARDED_MESSAGE_ASSISTANT_ENABLED=true
DRAFT_REPLY_ENABLED=true
GROUP_ASSISTANT_ENABLED=true
GUEST_MODE_ENABLED=false
GUEST_MODE_ADMIN_ONLY=true
GUEST_MODE_MAX_TOKENS=512
# Optional. Requires Telegram Business / Secretary Mode.
BUSINESS_MODE_ENABLED=false
BUSINESS_ADMIN_ONLY=true
BUSINESS_REPLY_ENABLED=false
BUSINESS_REPLY_TRIGGER=!jarvis
BUSINESS_MEMORY_MAX_MESSAGES=10
BUSINESS_ALLOWED_CONNECTION_IDS=
BUSINESS_ALLOWED_CHAT_IDS=
YANDEX_AI_BASE_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_AI_API_KEY=
YANDEX_AI_FOLDER_ID=
YANDEX_AI_MODEL= # gpt://<folder_ID>/<model_ID>/latest
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL= # auto-selected from /api/v1/models when possible
LOG_LEVEL=INFO
