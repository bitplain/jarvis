# Host-side polling overrides for local Mac smoke.
# Copy only non-secret overrides into local .env when running scripts/run_polling.py from host.
# Keep real tokens, API keys, admin ids and model ids in local .env only.

POSTGRES_HOST=localhost
REDIS_URL=redis://localhost:6379/0
GUEST_MODE_ENABLED=true
GUEST_MODE_ADMIN_ONLY=true
